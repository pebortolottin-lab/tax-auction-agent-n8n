{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "valuation",
  "type": "object",
  "required": ["run_id", "state", "county", "parcel_id", "minimum_bid", "estimated_market_value_mid"],
  "properties": {
    "run_id": { "type": "string" },
    "state": { "type": "string" },
    "county": { "type": "string" },
    "parcel_id": { "type": "string" },
    "minimum_bid": { "type": "number" },
    "taxes_due": { "type": ["number", "null"] },
    "assessed_value": { "type": ["number", "null"] },
    "estimated_market_value_low": { "type": "number" },
    "estimated_market_value_mid": { "type": "number" },
    "estimated_market_value_high": { "type": "number" },
    "margin_pct": { "type": "number" },
    "valuation_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valuation_status": { "type": "string", "enum": ["high_confidence", "medium_confidence", "low_confidence"] },
    "source_links": { "type": "array", "items": { "type": "string" } },
    "last_verified_at": { "type": "string", "format": "date-time" }
  }
}
